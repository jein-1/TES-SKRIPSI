{
  "name": "tes-project-skripsi",
  "version": "0.0.30",
  "type": "module",
  "scripts": {
    "dev:frontend": "cd frontend && npm run dev",
    "dev": "npm run dev:frontend",
    "build": "cd frontend && npm run build",
    "build:admin": "cd frontend && npm run build:admin",
    "bump": "node tools/bump-version.js",
    "install:all": "npm install && cd frontend && npm install",
    "cap:sync": "node tools/bump-version.js && npm run build && npx cap sync android && npm run build:admin && node tools/cap-admin-sync.js",
    "cap:open": "npx cap open android",
    "cap:open:admin": "node tools/cap-admin-open.js",
    "cap:build": "npm run build && npx cap sync",
    "cap:run": "npx cap run android",
    "git:push": "git add . && git commit -m \"update\" && git push"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.1",
    "@capacitor/app": "^8.1.1",
    "@capacitor/background-runner": "^3.0.0",
    "@capacitor/camera": "^8.2.1",
    "@capacitor/cli": "^8.3.1",
    "@capacitor/core": "^8.3.1",
    "@capacitor/device": "^8.0.3",
    "@capacitor/geolocation": "^8.2.0",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/local-notifications": "^8.2.1",
    "@capacitor/network": "^8.0.1",
    "@capacitor/preferences": "^8.0.1",
    "@capacitor/splash-screen": "^8.0.2",
    "@capacitor/status-bar": "^8.0.3",
    "@supabase/supabase-js": "^2.110.7",
    "concurrently": "^9.2.1",
    "cors": "^2.8.6",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "ts-node": "^10.9.2",
    "typescript": "^7.0.2"
  }
}
