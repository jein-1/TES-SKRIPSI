# Admin APK build config
# ─────────────────────────────────────────────────────────────
# URL Railway — hanya base URL, tanpa /?admin atau #admin
# Mode admin sudah di-handle oleh VITE_ADMIN_APP=true di bawah
VITE_API_URL=https://tes-skripsi-production.up.railway.app

# Forces admin mode dalam APK (jangan hapus)
VITE_ADMIN_APP=true
